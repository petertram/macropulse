{
  "name": "beats-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "postinstall": "npm install -g concurrently",
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w server\"",
    "build": "npm run build -w frontend",
    "start": "npm run start -w server"
  }
}