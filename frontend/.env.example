# VITE_GEMINI_API_KEY: Required for Gemini AI API calls.
# Note: Variables must start with VITE_ to be available on the client-side.
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:5173"

# FRED_API_KEY: Used to fetch live macroeconomic data from the Federal Reserve Economic Data API.
FRED_API_KEY="4030789b3b214aeade239a08babaa32a"
