# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this to your local Gemini API key.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:5173"

# FRED_API_KEY: Used to fetch live macroeconomic data from the Federal Reserve Economic Data API.
FRED_API_KEY="4030789b3b214aeade239a08babaa32a"
